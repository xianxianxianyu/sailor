{
  "name": "sailor-desktop",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n BACKEND,FRONTEND -c green,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
    "desktop:dev": "electron .",
    "dev:backend": "python -m uvicorn backend.app.main:app --host 127.0.0.1 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev -- --host localhost --port 5173",
    "install:frontend": "npm --prefix frontend install",
    "install:backend": "python -m pip install -r backend/requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^36.0.0"
  }
}
